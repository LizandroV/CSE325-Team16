@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="brand">
                <span class="brand-icon">🍽</span>
                <div class="brand-text">
                    <span class="brand-name">La Casa Peruana</span>
                    <span class="brand-tagline">Sabor auténtico del Perú</span>
                </div>
            </a>
            <nav class="site-nav">
                <a href="/" class="nav-link">Menú</a>
                @if (AuthService.EstaAutenticado)
                {
                    <a href="/admin" class="nav-link">Admin</a>
                    <button class="btn-logout" @onclick="Logout">Salir</button>
                }
                else
                {
                    <a href="/login" class="nav-link btn-login">Ingresar</a>
                }
            </nav>
            <button class="hamburger" @onclick="ToggleMenu" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
        @if (menuOpen)
        {
            <nav class="mobile-nav">
                <a href="/" class="nav-link" @onclick="CloseMenu">Menú</a>
                @if (AuthService.EstaAutenticado)
                {
                    <a href="/admin" class="nav-link" @onclick="CloseMenu">Administración</a>
                    <button class="btn-logout" @onclick="Logout">Cerrar Sesión</button>
                }
                else
                {
                    <a href="/login" class="nav-link" @onclick="CloseMenu">Ingresar</a>
                }
            </nav>
        }
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <p class="footer-brand">🍽 La Casa Peruana</p>
            <p class="footer-copy">© 2025 · Todos los derechos reservados</p>
            <p class="footer-address">Lima, Perú · Reservas: (01) 234-5678</p>
        </div>
    </footer>
</div>

@code {
    bool menuOpen = false;

    protected override void OnInitialized()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
    }

    void ToggleMenu() => menuOpen = !menuOpen;
    void CloseMenu() => menuOpen = false;

    void Logout()
    {
        AuthService.Logout();
        menuOpen = false;
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }
}
